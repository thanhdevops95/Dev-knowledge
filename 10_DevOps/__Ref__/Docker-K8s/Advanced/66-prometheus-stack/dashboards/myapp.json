{
  "title": "myapp — RED metrics",
  "uid": "myapp-red",
  "schemaVersion": 39,
  "version": 1,
  "tags": ["myapp", "red"],
  "timezone": "browser",
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "15s",
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "RPS (Rate) — requests/giây theo endpoint",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(myapp_request_total[1m])) by (endpoint)",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error rate (Errors) — 5xx / tổng",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(myapp_request_total{status=\"500\"}[5m])) / sum(rate(myapp_request_total[5m]))",
          "legendFormat": "error ratio",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Latency P95 (Duration)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(myapp_request_duration_seconds_bucket[5m])) by (le, endpoint))",
          "legendFormat": "P95 {{endpoint}}",
          "refId": "A"
        }
      ]
    }
  ]
}
